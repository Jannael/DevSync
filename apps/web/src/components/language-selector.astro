---
import { translations } from '@/i18n/translation'

const currentLang = Astro.currentLocale ?? 'en'
const currentPath = Astro.url.pathname
---

<div role="group" aria-label="Language selection" class="language-selector">
  <label for="lang-select" class="sr-only">Select language</label>
  <select
    id="lang-select"
    class="border-border bg-surface text-text hover:border-accent hover:bg-surface-raised focus:border-accent focus:ring-accent/20 cursor-pointer rounded-lg border px-2 py-1.5 text-xs font-medium transition-all focus:outline-none focus:ring-2 sm:px-4 sm:py-2 sm:text-sm"
  >
    {
      Object.keys(translations).map((lang) => (
        <option value={lang} selected={lang === currentLang}>
          {lang.toUpperCase()}
        </option>
      ))
    }
  </select>
</div>

<script>
  const select = document.getElementById('lang-select') as HTMLSelectElement
  if (select) {
    select.addEventListener('change', (e) => {
      const newLang = (e.target as HTMLSelectElement).value
      const currentPath = window.location.pathname
      const pathWithoutLang = currentPath.replace(/^\/(en|es)/, '')
      window.location.href = `/${newLang}${pathWithoutLang || '/'}`
    })
  }
</script>
