{
  "name": "devsync",
  "version": "develop version",
  "private": false,
  "type": "module",
  "description": "One file to keep your portfolio, CV, Github and linkedin in sync",
  "license": "CC-BY-NC-4.0",
  "bin": {
    "devsync": "apps/cli/index.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Jannael/devsync.git"
  },
  "author": {
    "name": "Jannael",
    "url": "https://github.com/jannael"
  },
  "homepage": "https://devsync.work",
  "bugs": {
    "url": "https://github.com/jannael/devsync/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "portfolio",
    "cv",
    "github",
    "linkedin",
    "sync"
  ],
  "files": [
    "dist",
    "DEVSYNC.json"
  ],
  "exports": {
    ".": "./apps/cli/index.ts"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "build": "bun build ./apps/cli/index.ts --outfile=./dist/index.js --target=bun",
    "prepublishOnly": "bun run build",

    "lint": "oxlint --quiet --ignore-pattern \"*.js\"",
    "lint:fix": "oxlint --fix --ignore-pattern \"*.js\"",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0"
  },
  "peerDependencies": {
    "typescript": "5"
  }
}
