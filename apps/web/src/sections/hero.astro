---
import AsciiScramble from '@/components/ascii-scramble.astro'
import { devsyncASCII } from '@/devsync-ascii'
import { getTranslation } from '@/i18n/translation'
import { getRelativeLocaleUrl } from 'astro:i18n'

const lang = Astro.currentLocale ?? 'en'
const t = getTranslation(lang)
---

<section class="flex flex-col items-center gap-6 px-8 py-16">
  <AsciiScramble lines={devsyncASCII} />
  <p class="text-text-secondary max-w-[600px] text-center">{t['Synchronization tool...']}</p>
  <a
    href={getRelativeLocaleUrl(lang, '/getting-started/')}
    class="bg-btn-primary text-btn-primary-foreground hover:bg-btn-primary-hover inline-block rounded-md px-8 py-3 font-semibold transition-colors"
  >
    {t['Start Now']}
  </a>
</section>
