---
const chars = ['тФА', 'тХР', 'тФД', 'тФИ', 'тФЙ', 'тХ┤', 'тХ╢']
const width = 300
const lines = 3

function generateSeparator() {
  const result: string[] = []

  for (let i = 0; i < lines; i++) {
    const line = Array.from(
      { length: width },
      () => chars[Math.floor(Math.random() * chars.length)]
    ).join('')
    result.push(line)
  }

  return result.join('\n')
}

const separatorASCII = generateSeparator()
---

<div class="w-full py-8" aria-hidden="true">
  <div
    class="ascii-separator transform-[skewY(-2deg)_rotate(-1deg)] mx-auto w-screen max-w-none origin-center"
  >
    <pre
      class="text-accent whitespace-pre text-center font-mono text-xs leading-[1.2] opacity-30 [text-shadow:0_0_8px_var(--color-accent)] dark:opacity-40">{separatorASCII}</pre>
  </div>
</div>

<style>
  .ascii-separator {
    transform: skewY(-2deg) rotate(-1deg);
    transform-origin: center;
  }
</style>
