---
import Layout from '@/layouts/layout.astro'
import AsciiScramble from '@/components/ascii-scramble.astro'
import { devsyncASCII } from '@/devsync-ascii'
import { getTranslation } from '@/i18n/translation'
import { getRelativeLocaleUrl } from 'astro:i18n'

const lang = Astro.currentLocale ?? 'en'
const t = getTranslation(lang)
---

<Layout title="404 - Not Found">
  <section class="flex flex-col items-center justify-center gap-6 py-16 px-8 min-h-[70vh]">
    <AsciiScramble lines={devsyncASCII} />
    <h1 class="text-4xl font-bold text-text mt-8">{t['Page not found']}</h1>
    <p class="max-w-[600px] text-center text-text-secondary">{t['The page you are looking for does not exist.']}</p>
    <div class="flex flex-col sm:flex-row gap-4 mt-4">
      <a
        href={getRelativeLocaleUrl(lang, '/')}
        class="inline-block px-8 py-3 bg-btn-primary text-btn-primary-foreground rounded-md font-semibold transition-colors hover:bg-btn-primary-hover text-center"
      >
        {t['Go to Home']}
      </a>
      <a
        href={getRelativeLocaleUrl(lang, '/getting-started/')}
        class="inline-block px-8 py-3 border border-btn-primary text-btn-primary rounded-md font-semibold transition-colors hover:bg-btn-primary/10 text-center"
      >
        {t['Getting Started']}
      </a>
    </div>
  </section>
</Layout>
