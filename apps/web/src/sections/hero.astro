---
import AsciiScramble from '@/components/ascii-scramble.astro'
import BackgroundGrid from '@/components/background-grid.astro'
import { devsyncASCII } from '@/devsync-ascii'
import { getTranslation } from '@/i18n/translation'
import { getRelativeLocaleUrl } from 'astro:i18n'

const lang = Astro.currentLocale ?? 'en'
const t = getTranslation(lang)
---

<section
  class="hero relative flex min-h-screen flex-col items-center justify-center overflow-hidden px-6 py-24"
>
  <BackgroundGrid />

  <!-- Radial glow behind ASCII -->
  <div
    class="hero-glow pointer-events-none absolute left-1/2 top-1/3 z-0 -translate-x-1/2 -translate-y-1/2"
  >
  </div>

  <div class="relative z-10 flex w-full max-w-4xl flex-col items-center text-center">
    <!-- ASCII Logo with scramble animation -->
    <div class="hero-ascii mb-10">
      <AsciiScramble lines={devsyncASCII} />
    </div>

    <!-- Tagline -->
    <p class="hero-tagline text-accent mb-16 text-sm font-semibold uppercase tracking-[0.3em]">
      {t['Resume. Portfolio. GitHub profile.']}
    </p>

    <!-- Main headline -->
    <h1
      class="hero-title text-text mb-6 text-2xl font-semibold tracking-tight sm:text-3xl md:text-4xl lg:text-5xl"
    >
      {t['Synchronization tool for developers']}
    </h1>

    <!-- Description -->
    <p
      class="hero-description text-text-secondary mx-auto mb-16 max-w-2xl text-lg leading-relaxed md:text-xl"
    >
      {t['Generate your professional resume...']}
    </p>

    <!-- CTAs -->
    <div class="hero-ctas flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href={getRelativeLocaleUrl(lang, '/getting-started/')}
        class="text-btn-primary-foreground bg-btn-primary hover:bg-btn-primary-hover group inline-flex items-center justify-center gap-2 rounded-xl px-8 py-4 font-bold shadow-lg transition-all duration-300 hover:scale-105 active:scale-95"
      >
        {t['Start Now']}
      </a>
    </div>
  </div>
</section>

<style>
  .hero-glow {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, var(--color-accent) 0%, transparent 70%);
    opacity: 0.04;
    filter: blur(80px);
  }

  :global(.dark) .hero-glow {
    opacity: 0.06;
  }

  /* ── Entrance animations ────────────────────────────── */
  .hero-ascii,
  .hero-tagline,
  .hero-title,
  .hero-description,
  .hero-ctas {
    opacity: 0;
    transform: translateY(20px);
    animation: hero-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero-ascii {
    animation-delay: 0s;
  }
  .hero-tagline {
    animation-delay: 0.15s;
  }
  .hero-title {
    animation-delay: 0.3s;
  }
  .hero-description {
    animation-delay: 0.45s;
  }
  .hero-ctas {
    animation-delay: 0.6s;
  }

  @keyframes hero-fade-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
