---
import GitHub from '@/assets/github-svg.astro'
import { getTranslation } from '@/i18n/translation'

const lang = Astro.currentLocale ?? 'en'
const t = getTranslation(lang)

const paragraphs = t['creator description'].split('\n\n')
---

<section
  id="creator-section"
  class="creator relative flex flex-col items-center justify-center overflow-hidden px-4 pb-16 pt-8 sm:px-6 sm:pb-24 sm:pt-12"
  aria-labelledby="creator-title"
>
  <div class="relative z-10 flex w-full max-w-4xl flex-col items-center">
    <!-- Terminal-style card -->
    <div
      class="creator-card border-border bg-surface w-full overflow-hidden rounded-xl border shadow-sm"
    >
      <!-- Terminal header -->
      <div
        class="border-border bg-surface-sunken flex items-center gap-2 border-b px-4 py-2.5 sm:px-5"
      >
        <div class="flex gap-1.5">
          <span class="bg-error/60 h-3 w-3 rounded-full"></span>
          <span class="bg-warning/60 h-3 w-3 rounded-full"></span>
          <span class="bg-success/60 h-3 w-3 rounded-full"></span>
        </div>
        <span class="text-text-muted ml-2 font-mono text-xs sm:text-sm">~/devsync/creator</span>
      </div>

      <!-- Terminal body -->
      <div class="flex flex-col gap-6 p-5 sm:flex-row sm:gap-8 sm:p-8">
        <!-- Left: Avatar + ASCII -->
        <div class="flex flex-col items-center gap-4 sm:w-48 sm:shrink-0">
          <img
            src="https://avatars.githubusercontent.com/u/177653963?v=4"
            alt="jannael's GitHub avatar"
            class="ring-accent/20 h-20 w-20 rounded-full object-cover ring-2 sm:h-24 sm:w-24"
            loading="lazy"
          />
          <div class="text-accent hidden sm:block">
            <pre
              class="font-mono text-[0.35rem] leading-[1.05]">
{`   __
  / /_
 / __ \\
/_/ /_/
`}
            </pre>
          </div>
          <a
            href="https://github.com/jannael"
            target="_blank"
            rel="noopener noreferrer"
            class="text-accent hover:text-accent-hover inline-flex items-center gap-1.5 text-sm font-medium transition-colors"
          >
            <span>@jannael</span>
            <GitHub class="h-4 w-4" />
          </a>
        </div>

        <!-- Right: Content -->
        <div class="flex flex-col gap-4">
          <h2 id="creator-title" class="creator-title text-text text-lg font-semibold sm:text-xl">
            {t['The Creator']}
          </h2>
          <div class="creator-content text-text-secondary text-base leading-relaxed sm:text-lg">
            <p class="creator-description">{paragraphs[0]}</p>
            <p class="mt-4">{paragraphs[1]}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function setupObserver() {
    const section = document.getElementById('creator-section')
    if (!section) return
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            section.classList.add('animate')
            observer.disconnect()
          }
        })
      },
      { threshold: 0.1 }
    )
    observer.observe(section)
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupObserver)
  } else {
    setupObserver()
  }
</script>

<style>
  /* ── Entrance animations ── */
  .creator-card {
    opacity: 0;
    transform: translateY(20px);
  }

  .creator.animate .creator-card {
    animation: creator-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .creator-description {
    opacity: 0;
    transform: translateY(10px);
  }

  .creator.animate .creator-description {
    animation: creator-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
  }

  @keyframes creator-fade-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Dark mode card adjustments ── */
  :global(.dark) .creator-card {
    border-color: color-mix(in srgb, var(--color-border) 50%, transparent);
  }
</style>
