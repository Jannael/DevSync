---
import Layout from '@/layouts/layout.astro'
import BackgroundGrid from '@/components/background-grid.astro'

import { magnifyinfASCII } from '@/magnifying-ascii'
import { getTranslation } from '@/i18n/translation'
import { getRelativeLocaleUrl } from 'astro:i18n'

const lang = Astro.currentLocale ?? 'en'
const t = getTranslation(lang)
---

<Layout title="404 - Not Found">
  <section
    class="bg-bg relative flex min-h-screen flex-col items-center justify-center overflow-hidden px-6 py-24"
  >
    <BackgroundGrid />

    <!-- Large decorative "404" in background -->
    <div
      class="pointer-events-none absolute inset-0 z-0 flex select-none items-center justify-center"
    >
      <span class="text-text text-[25vw] font-black leading-none opacity-[0.02] dark:opacity-[0.03]"
        >404</span
      >
    </div>

    <div class="relative z-10 flex w-full max-w-2xl flex-col items-center text-center">
      <!-- ASCII Art Container with Glassmorphism -->
      <div class="mb-12 transition-transform duration-700 hover:scale-105">
        <div
          class="bg-surface-raised/40 border-border-subtle dark:shadow-accent/5 rounded-3xl border p-8 shadow-2xl backdrop-blur-md md:p-12"
        >
          <pre class="ascii-art">{magnifyinfASCII.join('\n')}</pre>
        </div>
      </div>

      <!-- Content with entrance animations -->
      <div class="animate-in fade-in slide-in-from-bottom-4 fill-mode-both space-y-6 duration-1000">
        <h1 class="text-text text-5xl font-black tracking-tighter md:text-7xl">
          {t['Page not found']}
        </h1>

        <p class="text-text-secondary mx-auto max-w-md text-lg leading-relaxed md:text-xl">
          {t['The page you are looking for does not exist.']}
        </p>

        <div class="flex flex-col items-center justify-center gap-4 pt-8 sm:flex-row">
          <a
            href={getRelativeLocaleUrl(lang, '/')}
            class="text-btn-primary-foreground bg-btn-primary hover:bg-btn-primary-hover shadow-btn-primary/10 group relative inline-flex items-center justify-center rounded-xl px-8 py-4 font-bold shadow-lg transition-all duration-300 hover:scale-105 active:scale-95"
          >
            <span class="relative flex items-center gap-2">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline
                  points="9 22 9 12 15 12 15 22"></polyline></svg
              >
              {t['Go to Home']}
            </span>
          </a>

          <a
            href={getRelativeLocaleUrl(lang, '/getting-started/')}
            class="text-text bg-surface border-border-strong hover:bg-bg-alt hover:border-accent hover:text-accent group inline-flex items-center justify-center rounded-xl border px-8 py-4 font-bold shadow-sm transition-all duration-300 hover:scale-105 active:scale-95"
          >
            <span class="flex items-center gap-2">
              {t['Getting Started']}
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="transition-transform group-hover:translate-x-1"
                ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
              >
            </span>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .ascii-art {
    font-family: monospace;
    font-size: 12px;
    line-height: 1.1;
    white-space: pre;
    color: var(--color-accent);
    text-shadow:
      0 0 5px var(--color-accent),
      0 0 10px var(--color-accent);
    display: block;
    margin: 0 auto;
    background: transparent;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes slide-in-from-bottom {
    from {
      transform: translateY(30px);
    }
    to {
      transform: translateY(0);
    }
  }

  .animate-in {
    animation: fade-in 1.2s ease-out forwards;
  }

  .slide-in-from-bottom-4 {
    animation: slide-in-from-bottom 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .fill-mode-both {
    animation-fill-mode: both;
  }
</style>
